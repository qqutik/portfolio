# Значення за замовчуванням для Symfony-застосунку.
# Реальні змінні оточення (зокрема ті, що задані в docker-compose.yml) мають
# пріоритет над цим файлом, бо Dotenv::load() не перезаписує наявні env.
# DO NOT DEFINE PRODUCTION SECRETS HERE. https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=18fcfe1841597447313927bdcddd5a0c
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8000
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Використовується, коли до проєкту додадуть Doctrine ORM.
DATABASE_URL="postgresql://app:app@database:5432/app?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###
